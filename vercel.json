{
  "routes": [
    {
      "src": "^/$",
      "dest": "/landing.html"
    },
    {
      "src": "^/privacy-policy$",
      "dest": "/privacy-policy.html"
    },
    {
      "src": "^/terms$",
      "dest": "/terms.html"
    },
    {
      "src": "^/refund$",
      "dest": "/refund.html"
    },
    {
      "src": "^/contact$",
      "dest": "/contact.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/app(/.*)?$",
      "dest": "/index.html"
    }
  ]
}
